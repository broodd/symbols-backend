{
  "name": "symbols-backend",
  "version": "0.0.1",
  "description": "Symbols backend",
  "author": {
    "name": "broodd",
    "email": "svyatddev@gmail.com",
    "url": "https://github.com/broodd"
  },
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": ">=10.x"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "mjml:build": "ts-node src/sendmail/compile-mjml.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "cross-env NODE_ENV=development nest start",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/main",
    "typeorm:cli": "cross-env NODE_ENV=development node -r tsconfig-paths/register -r ts-node/register ./node_modules/typeorm/cli --d ./src/database/typeorm-migration.config.ts",
    "typeorm:create:migration": "npm run typeorm:cli -- migration:create -d src/database/migrations -n",
    "typeorm:migration:gen": "npm run typeorm:cli -- migration:generate src/database/migrations/migration",
    "doc": "npm run doc:generate -- -s",
    "doc:generate": "npx @compodoc/compodoc -p tsconfig.json -d docs --theme laravel",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "npm run test -- --watch",
    "test:cov": "npm run test -- --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prepare": "sh -c 'if test \"$NODE_ENV\" -ne \"production\" ; then husky install ; fi' ",
    "cli": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register src/database/seeds/cli.ts",
    "seed:admin": "npm run cli -- seed:admin",
    "seed:admin:prod": "cross-env NODE_ENV=production node dist/database/seeds/cli.js seed:admin"
  },
  "dependencies": {
    "@binance/spot": "^28.0.5",
    "@fastify/basic-auth": "^5.1.1",
    "@fastify/compress": "^7.0.3",
    "@fastify/cookie": "^7.4.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/multipart": "^7.7.3",
    "@fastify/swagger": "^8.8.0",
    "@nestjs/axios": "^3.1.3",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^10.1.2",
    "@nestjs/core": "^10.1.2",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.1.2",
    "@nestjs/swagger": "^7.1.4",
    "@nestjs/terminus": "^10.0.1",
    "@nestjs/throttler": "^4.2.1",
    "@nestjs/typeorm": "^10.0.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "mongoose": "^8.23.0",
    "nestjs-command": "^3.1.5",
    "nestjs-pino": "^4.5.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.6.7",
    "@commitlint/config-angular": "^17.6.7",
    "@compodoc/compodoc": "^1.1.21",
    "@eslint/object-schema": "^2.0.3",
    "@nestjs/cli": "^10.1.10",
    "@nestjs/schematics": "^10.0.1",
    "@nestjs/testing": "^10.1.2",
    "@types/dotenv": "^8.2.0",
    "@types/jest": "^29.5.3",
    "@types/node": "^20.4.5",
    "@types/nodemailer": "^6.4.9",
    "@types/passport": "^1.0.12",
    "@types/passport-jwt": "^3.0.9",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.2.0",
    "@typescript-eslint/parser": "^6.2.0",
    "chai": "^4.3.7",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.9.0",
    "eslint-plugin-import": "^2.28.0",
    "eslint-plugin-perfectionist": "^4.9.0",
    "husky": "^8.0.3",
    "jest": "^29.6.2",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.1",
    "sinon": "^15.2.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.4.4",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.6"
  },
  "jest": {
    "verbose": true,
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1",
      "^test/(.*)$": "<rootDir>/test/$1"
    },
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "testEnvironment": "node",
    "testRegex": "/src/.*\\.(test|spec).(ts|tsx|js)$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/src/database/migrations/"
    ],
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ]
  },
  "compodoc": {
    "open": true,
    "hideGenerator": true,
    "output": "./public",
    "tsconfig": "./tsconfig.json",
    "unitTestCoverage": "./coverage/coverage-summary.json"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run format && npm run lint -- --cache",
      "commit-msg": "commitlint -c .commitlintrc.json -E HUSKY_GIT_PARAMS"
    }
  }
}
